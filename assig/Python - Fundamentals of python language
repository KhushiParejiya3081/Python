# Write a Python program that demonstrates the correct use of indentation, comments, and variables following PEP 8 guidelines.

# This program demonstrates PEP 8 style:
# - Proper indentation (4 spaces)
# - Meaningful variable names
# - Use of comments


def greet_user():
    """Function to greet the user with their name."""

    # Store user's name in a variable
    user_name = "Khushi"

    # Create a greeting message
    greeting_message = f"Hello, {user_name}! Welcome to Python programming."

    # Display the message
    print(greeting_message)


# Main program execution starts here
if __name__ == "__main__":
    greet_user()




